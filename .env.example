# Anthropic API key (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model used for vision + reasoning. Defaults to claude-opus-4-6
# (best quality). Override to claude-sonnet-4-5 for ~5x lower cost and
# faster responses if you don't need Opus-level reasoning.
# ANTHROPIC_MODEL=claude-opus-4-6

# Supabase (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-side service role for admin tasks (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public site URL for magic-link redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
